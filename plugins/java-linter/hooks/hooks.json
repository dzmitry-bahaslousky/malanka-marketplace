{
  "description": "Run Spotless formatter after Java file edits",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PLUGIN_ROOT/hooks/scripts/spotless.py",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
